# ============================================
# AirNext - Variáveis de Ambiente
# ============================================

# Domínio público usado para gerar as URLs gravadas nos chips NFC e nos QR
# Codes (ex.: https://seudominio.com/n/{uuid}). Enquanto não tiver domínio
# próprio, aponte para a URL da Vercel usada em produção.
VITE_PUBLIC_APP_URL=https://airnext-xi.vercel.app

# API
VITE_API_URL=

# Analytics
VITE_GOOGLE_ANALYTICS_ID=
VITE_HOTJAR_ID=

# Sentry (Error Tracking)
VITE_SENTRY_DSN=

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_SOCIAL_LOGIN=false

# Environment
NODE_ENV=development
